# Supabase Configuration Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# =============================================================================
# PUBLIC KEYS (Safe to expose in browser - protected by Row Level Security)
# =============================================================================
VITE_SUPABASE_URL=https://pzenkzipagidjtsdxaxe.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key-here

# =============================================================================
# PRIVATE KEYS (NEVER expose in browser - server-side only!)
# WARNING: secret key bypasses Row Level Security
# =============================================================================
VITE_SUPABASE_SECRET_KEY=your-secret-key-here

# =============================================================================
# DATABASE (Optional - for direct PostgreSQL connection)
# =============================================================================
# Get connection string from: Supabase Dashboard > Settings > Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.pzenkzipagidjtsdxaxe.supabase.co:5432/postgres
DATABASE_ADMIN_URL=postgresql://postgres:[YOUR-PASSWORD]@db.pzenkzipagidjtsdxaxe.supabase.co:5432/postgres

# =============================================================================
# CLOUDFLARE R2 STORAGE (Media)
# =============================================================================
R2_ACCOUNT_ID=5255727b7269584897c8c97ebdd3347f
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=awcms-personalfinance

# =============================================================================
# CLOUDFLARE TURNSTILE (CAPTCHA Protection)
# =============================================================================
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key
VITE_TURNSTILE_SITE_KEY_MAP='{"personalfinance.ahlikoding.com":"your-site-key"}'
VITE_TURNSTILE_DEBUG=false

# =============================================================================
# CLOUDFLARE PAGES (Deployment)
# =============================================================================
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# =============================================================================
# SUPABASE S3 STORAGE (Server-side)
# =============================================================================
SUPABASE_S3_ENDPOINT=https://your-project-id.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=your-region
SUPABASE_S3_ACCESS_KEY_ID=your-access-key-id
SUPABASE_S3_SECRET_ACCESS_KEY=your-secret-access-key
SUPABASE_S3_BUCKET=your-bucket-name

# =============================================================================
# SUPABASE OAUTH (for Third-Party Integrations)
# =============================================================================
SUPABASE_OAUTH_CLIENT_ID=your-oauth-client-id
SUPABASE_OAUTH_CLIENT_SECRET=your-oauth-client-secret

# =============================================================================
# EMAIL JOBS (Mailketing)
# =============================================================================
MAILKETING_API_TOKEN=your-mailketing-api-token
MAILKETING_DEFAULT_LIST_ID=1
MAILKETING_SMTP_HOST=smtp.mailketing.id
MAILKETING_SMTP_PORT=587
MAILKETING_SMTP_USERNAME=your-smtp-username
MAILKETING_SMTP_PASSWORD=your-smtp-password
MAILKETING_FROM_NAME=Your Name
MAILKETING_FROM_EMAIL=your-email@example.com

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
VITE_SUPER_ADMIN_EMAIL=admin@meetuphsi.com

# Multi-Tenancy Development
VITE_DEV_TENANT_SLUG=personalfinance

# CORS Configuration
VITE_CORS_ALLOWED_ORIGINS=http://localhost:3000

# Public Portal Preview
VITE_PUBLIC_PORTAL_URL=http://localhost:4321
VITE_PREVIEW_SECRET=your-preview-secret-here

# =============================================================================
# MCP CONFIGURATIONS (Optional)
# =============================================================================
CONTEXT7_API_KEY=your-context7-api-key
